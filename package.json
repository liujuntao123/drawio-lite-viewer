{
  "name": "@your-scope/drawio-editor",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "draw.io runtime packaged for React and Vue iframe integrations.",
  "files": [
    "dist",
    "NPM_PACKAGE.md",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "default": "./dist/vue/index.js"
    },
    "./drawio/*": "./dist/drawio/*"
  },
  "peerDependencies": {
    "react": ">=18",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "scripts": {
    "build": "node scripts/build-npm-package.js",
    "build:static": "node scripts/prepare-static-deploy.js",
    "build:npm": "node scripts/build-npm-package.js",
    "check": "node scripts/prepare-static-deploy.js --check",
    "test": "node --test test/core.test.js",
    "preview": "node scripts/serve-dist.js",
    "deploy:vercel": "npm run build:static && npx vercel --prod",
    "deploy:cloudflare": "npm run build:static && npx wrangler pages deploy dist"
  }
}
